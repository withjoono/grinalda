# 환경 설정
ENV=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/jungsi_prediction

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-northeast3
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Vertex AI
VERTEX_AI_EMBEDDING_MODEL=text-embedding-005
VERTEX_AI_LLM_MODEL=gemini-1.5-pro
VECTOR_SEARCH_INDEX_ENDPOINT=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-super-secret-key-change-this

# Crawling
CRAWL_INTERVAL_NORMAL=3600
CRAWL_INTERVAL_APPLICATION=600
CRAWL_INTERVAL_FINAL=300
PROXY_ROTATION_ENABLED=false

# ML Model
ML_MODEL_PATH=models/ensemble_model.joblib
ML_PREDICTION_THRESHOLD=0.5
